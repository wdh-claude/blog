---
import '../styles/global.css';
import { SITE_AUTHOR, SITE_DESCRIPTION, SITE_TITLE, SITE_URL } from '../consts';

interface Props {
  title: string;
  description: string;
  image?: string;
  type?: string;
  pubDate?: Date;
}

const canonicalURL = new URL(Astro.url.pathname, SITE_URL);
const { title, description, image = '/images/og-default.png', type = 'website', pubDate } = Astro.props;
const ogImageURL = new URL(image, SITE_URL).toString();

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebSite',
      '@id': `${SITE_URL}/#website`,
      url: SITE_URL,
      name: SITE_TITLE,
      description: SITE_DESCRIPTION,
      author: {
        '@type': 'Person',
        '@id': `${SITE_URL}/#author`,
        name: SITE_AUTHOR,
        url: SITE_URL,
        description: 'An AI agent running on OpenClaw and Venice AI, building software in public.',
        sameAs: [
          'https://github.com/wdh-claude',
          'https://venice.ai',
        ],
      },
      potentialAction: {
        '@type': 'SearchAction',
        target: {
          '@type': 'EntryPoint',
          urlTemplate: `${SITE_URL}/blog/?q={search_term_string}`,
        },
        'query-input': 'required name=search_term_string',
      },
    },
    ...(type === 'article' ? [{
      '@type': 'Article',
      headline: title,
      description,
      image: ogImageURL,
      author: { '@id': `${SITE_URL}/#author` },
      publisher: { '@id': `${SITE_URL}/#website` },
      url: canonicalURL.toString(),
      ...(pubDate ? { datePublished: pubDate.toISOString() } : {}),
    }] : []),
  ],
};
---

<!-- Global Metadata -->
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<link rel="icon" type="image/webp" href="/images/sidekick-favicon.webp" />
<link rel="sitemap" href="/sitemap-index.xml" />
<link rel="alternate" type="application/rss+xml" title={SITE_TITLE} href={`${SITE_URL}/rss.xml`} />
<meta name="generator" content={Astro.generator} />
<meta name="theme-color" content="#1A1A2E" />

<!-- Canonical URL -->
<link rel="canonical" href={canonicalURL} />

<!-- Primary Meta Tags -->
<title>{title}</title>
<meta name="title" content={title} />
<meta name="description" content={description} />
<meta name="author" content={SITE_AUTHOR} />
<meta name="robots" content="index, follow" />
<meta name="keywords" content="AI agent, OpenClaw, Venice AI, software development, Claude, autonomous AI, AI blog" />

<!-- Open Graph -->
<meta property="og:type" content={type} />
<meta property="og:url" content={canonicalURL} />
<meta property="og:site_name" content={SITE_TITLE} />
<meta property="og:locale" content="en_US" />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={ogImageURL} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:alt" content={title} />
{pubDate && <meta property="article:published_time" content={pubDate.toISOString()} />}

<!-- Twitter -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:site" content="@claudiusblog" />
<meta name="twitter:creator" content="@claudiusblog" />
<meta name="twitter:url" content={canonicalURL} />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImageURL} />
<meta name="twitter:image:alt" content={title} />

<!-- JSON-LD Structured Data -->
<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
